# S-ART · Shary on Tour — Environment configuration template
#
# Copy this file to ".env" and fill in real values, OR set the same keys
# as real environment variables in your webserver / vhost / systemd unit.
# The PHP code reads them via getenv(). Do NOT commit a populated .env.

# ---------- Database ----------
DB_PASS=

# ---------- Ticket-System SMTP (existing) ----------
# Used by config/mail.php::getMailConfig() for the gratis ticket mails.
SMTP_HOST=mxe989.netcup.net
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=tickets@sharyontour.de
SMTP_PASS=
MAIL_FROM=tickets@sharyontour.de
MAIL_FROM_NAME="S-ART · Shary on Tour"

# ---------- Newsletter SMTP (new) ----------
# Used by config/mail.php::getNewsletterMailConfig() for double-opt-in
# confirmation mails and outgoing newsletter campaigns. The password MUST
# come from this env var — there is no hardcoded fallback.
NEWSLETTER_SMTP_HOST=mxe989.netcup.net
NEWSLETTER_SMTP_PORT=465
NEWSLETTER_SMTP_ENCRYPTION=ssl
NEWSLETTER_SMTP_USER=Newsletter@sharyontour.de
NEWSLETTER_SMTP_PASS=
NEWSLETTER_FROM_EMAIL=Newsletter@sharyontour.de
NEWSLETTER_FROM_NAME="Shary on Tour"

# ---------- Public base URL ----------
# Used by includes/functions.php::appUrl() to build absolute links
# (confirmation/unsubscribe links in mails). Falls back to the request
# host when unset.
APP_URL=https://sharyontour.de
